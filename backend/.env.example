# Server
HOST=0.0.0.0
PORT=3000

# Database
# SQLite file path: use ./prisma/dev.db for local dev, /data/brimble.db in Docker
DATABASE_URL="file:./prisma/dev.db"

# Caddy Configuration
CADDY_ADMIN_URL=http://caddy:2019
CADDY_DYNAMIC_DIR=/etc/caddy/dynamic
CADDYFILE_PATH=/etc/caddy/Caddyfile

# Build Pipeline
BRIMBLE_WORKSPACE=/data/work
RAILPACK_BIN=railpack
BUILDKIT_HOST=tcp://buildkit:1234

# Build Timeouts (milliseconds)
# Default: 60 minutes for build (Railpack can be slow on first run)
# Default: 2 minutes for deploy and serve stages
PIPELINE_BUILD_TIMEOUT_MS=3600000
PIPELINE_STAGE_TIMEOUT_MS=120000

# Local Registry (avoids slow "sending tarball" in WSL2)
# Push: internal Docker network via service name (port 5000 inside registry container)
# Pull: host loopback (port 5001 exposed on host, avoids Windows conflicts with WSL2)
BRIMBLE_REGISTRY_PUSH_HOST=registry:5000
BRIMBLE_REGISTRY_PULL_HOST=127.0.0.1:5001

# Runtime / Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock
BRIMBLE_HOST_PORT_MIN=10000
BRIMBLE_HOST_PORT_MAX=11000
BRIMBLE_CONTAINER_PORT=3000
BRIMBLE_HEALTH_POLL_MS=15000
BRIMBLE_DOCKER_UPSTREAM_HOST=host.docker.internal

# App URLs and Domains
BRIMBLE_APP_PUBLIC_BASE=http://localhost
BRIMBLE_APPS_BASE_DOMAIN=localhost

# Cloud / Production Configuration
# Uncomment and update these when deploying to a public server (EC2, etc.)

# CORS origins (comma-separated, include your public IP with http://)
# CORS_ORIGIN=http://<YOUR_PUBLIC_IP>,http://localhost

# Domain for deployed apps (use nip.io for wildcard DNS on any IP)
# With <YOUR_PUBLIC_IP>.nip.io, apps get URLs like: my-app-12345678.<YOUR_PUBLIC_IP>.nip.io
# BRIMBLE_APPS_BASE_DOMAIN=<YOUR_PUBLIC_IP>.nip.io

# Public URL base for accessing running apps
# BRIMBLE_APP_PUBLIC_BASE=http://<YOUR_PUBLIC_IP>

# Optional: GitHub token for private repositories (x-access-token style)
# GIT_TOKEN=ghp_xxxxxxxxxxxx

# Optional: Disable lockfile relaxation for Bun projects
# BRIMBLE_RAILPACK_DISABLE_LOCKFILE_RELAX=1
