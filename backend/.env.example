HOST=0.0.0.0
PORT=3000
# SQLite — local dev: file in prisma/; Docker: file on /data volume
DATABASE_URL="file:./prisma/dev.db"
# Docker compose example: DATABASE_URL="file:/data/brimble.db"
CADDY_ADMIN_URL=http://caddy:2019
# Path inside container (shared with Caddy) for per-deployment route snippets
CADDY_DYNAMIC_DIR=/etc/caddy/dynamic
CADDYFILE_PATH=/etc/caddy/Caddyfile

# Pipeline (Phase 3) — timeouts (ms)
# Build (clone + Railpack) — default 60m; WSL2 "sending tarball" can take 30m+
PIPELINE_BUILD_TIMEOUT_MS=3600000
# Deploy and serve stages each use this (default 2m)
PIPELINE_STAGE_TIMEOUT_MS=120000

# Phase 4 — Railpack build workspace and CLI
# In Docker: use a path on the /data volume (e.g. /data/work)
BRIMBLE_WORKSPACE=/data/work
RAILPACK_BIN=railpack
# Set to 1 to keep `bun install --frozen-lockfile` in the Railpack plan (fails for some real-world Bun repos).
# BRIMBLE_RAILPACK_DISABLE_LOCKFILE_RELAX=1
# BuildKit — must match the daemon (Compose: tcp://buildkit:1234). Required for `railpack build`.
BUILDKIT_HOST=tcp://buildkit:1234
# Local registry (optional): avoid BuildKit `sending tarball` by pushing to a registry and pulling by tag.
BRIMBLE_REGISTRY_PUSH_HOST=registry:5000
BRIMBLE_REGISTRY_PULL_HOST=127.0.0.1:5000
# Optional: HTTPS private Git (x-access-token style for GitHub)
GIT_TOKEN=

# Phase 6 — Runtime (dockerode, host port range, app port inside the built image)
DOCKER_SOCKET_PATH=/var/run/docker.sock
BRIMBLE_HOST_PORT_MIN=10000
BRIMBLE_HOST_PORT_MAX=11000
# Default container port for “server” apps (Express, etc.). Static sites built by Railpack run Caddy on 80.
BRIMBLE_CONTAINER_PORT=3000
BRIMBLE_HEALTH_POLL_MS=15000
# Public URL base for the running app (host browser): default http://localhost
BRIMBLE_APP_PUBLIC_BASE=http://localhost

# Phase 7 — Caddy (per-app vhost on port 80; requires CADDY_DYNAMIC_DIR in production)
# Right-hand side of the hostname: <name-slug>-<8chars>.<BRIMBLE_APPS_BASE_DOMAIN>
BRIMBLE_APPS_BASE_DOMAIN=localhost
# Where Caddy reverse_proxies to the host-mapped container port (Docker Desktop)
BRIMBLE_DOCKER_UPSTREAM_HOST=host.docker.internal

# Cloud / Production Configuration
# Uncomment and set these when deploying to a cloud server or production
# Example IP shown below: 13.50.5.50 (replace with your actual public IP)

# CORS: comma-separated list of allowed origins (include your public IP with http://)
# CORS_ORIGIN=http://13.50.5.50,http://localhost

# Base domain for deployed apps (use nip.io for wildcard DNS: your-ip.nip.io)
# This creates URLs like: my-app-12345678.13.50.5.50.nip.io
# BRIMBLE_APPS_BASE_DOMAIN=13.50.5.50.nip.io

# Alternative: use a real domain with wildcard DNS
# BRIMBLE_APPS_BASE_DOMAIN=apps.yourdomain.com

# Public base URL for app access (should match your public IP or domain)
# BRIMBLE_APP_PUBLIC_BASE=http://13.50.5.50
