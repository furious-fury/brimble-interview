HOST=0.0.0.0
PORT=3000
CORS_ORIGIN=http://localhost
# SQLite — local dev: file in prisma/; Docker: file on /data volume
DATABASE_URL="file:./prisma/dev.db"
# Docker compose example: DATABASE_URL="file:/data/brimble.db"
CADDY_ADMIN_URL=http://caddy:2019
# Path inside container (shared with Caddy) for per-deployment route snippets
CADDY_DYNAMIC_DIR=/etc/caddy/dynamic
CADDYFILE_PATH=/etc/caddy/Caddyfile

# Pipeline (Phase 3) — per-stage timeout in ms (build / deploy / serve)
# PIPELINE_STAGE_TIMEOUT_MS=120000

# Phase 4 — Railpack build workspace and CLI
# In Docker: use a path on the /data volume (e.g. /data/work)
# BRIMBLE_WORKSPACE=/data/work
# RAILPACK_BIN=railpack
# Optional: HTTPS private Git (x-access-token style for GitHub)
# GIT_TOKEN=

# Phase 6 — Runtime (dockerode, host port range, app port inside the built image)
# DOCKER_SOCKET_PATH=/var/run/docker.sock
# BRIMBLE_HOST_PORT_MIN=10000
# BRIMBLE_HOST_PORT_MAX=11000
# BRIMBLE_CONTAINER_PORT=3000
# BRIMBLE_HEALTH_POLL_MS=15000
# Public URL base for the running app (host browser): default http://localhost
# BRIMBLE_APP_PUBLIC_BASE=http://localhost
